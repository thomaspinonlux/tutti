# =============================================================================
# Tutti — .gitignore
# Sécurité critique : ce fichier doit être présent AVANT tout `git add`.
# =============================================================================

# ───── Secrets & credentials (NEVER COMMIT) ────────────────────────────────
credentials.env.local
credentials.env
*.env.local
.env
.env.*
!.env.example
!.env.*.example

# ───── Brief projet (privé, hors livrable) ────────────────────────────────
tutti-brief/
tutti-homepage-v2/
tutti-homepage-v2.zip

# ───── Node / pnpm ────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ───── Builds ─────────────────────────────────────────────────────────────
dist/
build/
out/
.next/
.turbo/
.vercel/
.cache/
.parcel-cache/
*.tsbuildinfo

# ───── TypeScript ─────────────────────────────────────────────────────────
*.tsbuildinfo

# ───── Vite ───────────────────────────────────────────────────────────────
.vite/

# ───── Tests / coverage ───────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ───── Logs ───────────────────────────────────────────────────────────────
logs/
*.log

# ───── IDE / éditeurs ─────────────────────────────────────────────────────
.idea/
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo
*~

# ───── OS ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ───── Prisma ─────────────────────────────────────────────────────────────
backend/prisma/migrations/dev.db*

# ───── Uploads runtime ────────────────────────────────────────────────────
uploads/
tmp/

# ───── Outils locaux ──────────────────────────────────────────────────────
.husky/_/
.vercel
exports/
