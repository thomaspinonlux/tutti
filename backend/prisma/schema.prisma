// Tutti — Schéma Prisma (multi-tenant strict)
//
// Convention: les colonnes en base sont en snake_case (via @map).
// Les modèles côté Prisma utilisent les noms du Document 02-ARCHITECTURE.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
//  WORKSPACES (entité de facturation)
// ─────────────────────────────────────────────────────────────────────────────

model Workspace {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  plan       Plan      @default(FREE)
  expires_at DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)

  members           WorkspaceMember[]
  establishments    Establishment[]
  music_credentials MusicProviderCredential[]

  @@map("workspaces")
}

enum Plan {
  FREE
  PAY_PER_NIGHT
  MONTHLY

  @@map("plan")
}

// ─────────────────────────────────────────────────────────────────────────────
//  WORKSPACE_MEMBERS (lien auth.users ↔ workspace, avec rôle)
// ─────────────────────────────────────────────────────────────────────────────

model WorkspaceMember {
  id                       String       @id @default(uuid()) @db.Uuid
  workspace_id             String       @db.Uuid
  user_id                  String       @db.Uuid // référence auth.users.id (Supabase Auth)
  role                     Role         @default(HOST)
  /// Phase 4 — Mode C : statut d'approbation manuelle.
  /// PENDING par défaut sauf si l'email est en whitelist ou si un
  /// invitation_code valide est utilisé à la création (→ APPROVED auto).
  /// Un super admin peut basculer PENDING → APPROVED ou REJECTED.
  status                   MemberStatus @default(PENDING)
  /// Email du compte au moment de la création (snapshot — auth.users
  /// peut changer l'email mais ce champ reste pour audit).
  email                    String?      @db.VarChar(320)
  /// Si la création est passée par un code invitation, on garde la trace
  /// du code utilisé (debug / traçabilité parrainage).
  invitation_code_used     String?      @db.VarChar(16)
  /// Date d'approbation (manuelle ou auto via whitelist/code). null
  /// tant que PENDING.
  approved_at              DateTime?    @db.Timestamptz(6)
  /// User id du super admin qui a approuvé (null si auto via whitelist
  /// ou code).
  approved_by              String?      @db.Uuid
  /// feat/admin-users-and-email-notifications — flag bloquage manuel par
  /// super-admin. Si true → middleware requireMember renvoie 403.
  is_blocked               Boolean      @default(false)
  blocked_at               DateTime?    @db.Timestamptz(6)
  blocked_by               String?      @db.Uuid
  /// Compteur freemium : nombre de sessions lancées dans le mois courant.
  /// Reset auto via comparaison freemium_period_start (1er du mois).
  /// Bouton "Réinitialiser compteur freemium" force à 0 + bump start_date.
  freemium_sessions_count  Int          @default(0)
  freemium_period_start    DateTime     @default(now()) @db.Timestamptz(6)
  /// Dernière activité user (dernier login OU action API). Affiché dans
  /// /admin/users + tri "Dernière connexion".
  last_seen_at             DateTime?    @db.Timestamptz(6)
  /// feat/granular-tracks-quizz-access — feature flags par user pour
  /// contrôler l'accès aux 2 modes Tutti. Défaut true (rétro-compat).
  /// Modifiable depuis /admin/users/:id par super-admin.
  can_use_tracks           Boolean      @default(true)
  can_use_quizz            Boolean      @default(true)
  /// feat/youtube-compliance — timestamp d'acceptation des CGU + Politique
  /// de confidentialité (checkbox required au signup). null pour les
  /// comptes legacy créés avant l'introduction de la checkbox — backfill
  /// possible via /admin/users/:id ou re-prompt à la prochaine connexion.
  /// Audit conformité YouTube API Services + RGPD.
  accepted_terms_at        DateTime?    @db.Timestamptz(6)
  // Système de parrainage (V1.1) — auto-généré à la création du membre,
  // 6 caractères alphanumériques majuscules (ex. "K7P2X9").
  referral_code            String?      @unique @db.VarChar(8)
  // Code du parrain si l'utilisateur s'est inscrit via un lien filleul.
  referrer_code            String?      @db.VarChar(8)
  /// Phase 3.5 — OAuth YouTube (scope youtube.readonly).
  /// Tokens chiffrés au repos par la DB (pas de chiffrement applicatif V1).
  youtube_access_token     String?      @db.Text
  youtube_refresh_token    String?      @db.Text
  youtube_token_expires_at DateTime?    @db.Timestamptz(6)
  /// Statut Premium détecté à la connexion (best-effort — aucune API publique
  /// fiable pour ça, défaut false. Peut être patché manuellement par l'utilisateur).
  youtube_premium          Boolean      @default(false)
  youtube_connected_at     DateTime?    @db.Timestamptz(6)
  /// Email du compte Google connecté (pour affichage UI).
  youtube_account_email    String?      @db.VarChar(320)
  created_at               DateTime     @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, user_id])
  @@index([user_id])
  @@index([status])
  @@map("workspace_members")
}

enum Role {
  OWNER
  HOST
  ANIMATOR

  @@map("role")
}

enum MemberStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("member_status")
}

// ─────────────────────────────────────────────────────────────────────────────
//  WHITELIST_EMAILS (Phase 4 — Mode C : approbation manuelle + bypass auto)
// ─────────────────────────────────────────────────────────────────────────────

/// Liste d'emails autoapprouvés à la création de compte. Si un nouvel
/// utilisateur s'inscrit avec un email présent dans cette table, son
/// WorkspaceMember est créé directement en APPROVED (pas de file d'attente).
/// Géré uniquement par les super admins.
model WhitelistEmail {
  id         String   @id @default(uuid()) @db.Uuid
  email      String   @unique @db.VarChar(320)
  /// Notes libres pour le super admin (ex: "ami early adopter", "prospect bar X")
  note       String?  @db.VarChar(500)
  /// User id du super admin qui a ajouté l'entrée.
  added_by   String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("whitelist_emails")
}

// ─────────────────────────────────────────────────────────────────────────────
//  PLAYLIST_SHARE_CODES (Phase 5 — partage playlist par code court)
// ─────────────────────────────────────────────────────────────────────────────

/// Code court (6 chars) qui pointe sur une playlist. Permet à un autre
/// animateur de cloner la playlist dans son workspace via /admin/import.
/// Single-use ou multi-usage selon max_uses. Expiration optionnelle.
model PlaylistShareCode {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique @db.VarChar(8)
  playlist_id String    @db.Uuid
  created_by  String    @db.Uuid // user_id auth.users
  max_uses    Int?
  uses_count  Int       @default(0)
  expires_at  DateTime? @db.Timestamptz(6)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)

  @@index([code])
  @@index([playlist_id])
  @@map("playlist_share_codes")
}

// ─────────────────────────────────────────────────────────────────────────────
//  INVITATION_CODES (Phase 4 — codes one-shot pour inscription auto-approuvée)
// ─────────────────────────────────────────────────────────────────────────────

/// Codes invitation générés par les super admins. Un code valide utilisé
/// lors de l'inscription bascule le WorkspaceMember directement en APPROVED.
/// Single-use par défaut (consumed_at une fois utilisé), expiration
/// optionnelle (expires_at). max_uses permet les codes multi-usage
/// (ex: campagne marketing avec un seul code partagé).
model InvitationCode {
  id            String    @id @default(uuid()) @db.Uuid
  code          String    @unique @db.VarChar(16)
  /// Notes libres (à qui ? campagne ?)
  note          String?   @db.VarChar(500)
  /// User id du super admin qui a généré le code.
  created_by    String    @db.Uuid
  /// Nombre d'utilisations max (null = illimité). Décompté dans uses_count.
  max_uses      Int?
  uses_count    Int       @default(0)
  expires_at    DateTime? @db.Timestamptz(6)
  /// Date du 1er use (info, pour audit). Avec max_uses=1, marque code consommé.
  first_used_at DateTime? @db.Timestamptz(6)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)

  @@index([code])
  @@map("invitation_codes")
}

// ─────────────────────────────────────────────────────────────────────────────
//  ESTABLISHMENTS (lieu physique ou thème)
// ─────────────────────────────────────────────────────────────────────────────

model Establishment {
  id               String   @id @default(uuid()) @db.Uuid
  workspace_id     String   @db.Uuid
  name             String
  branding_logo    String?
  branding_color   String?
  default_language String   @default("fr") @db.VarChar(8)
  /// Phase 3.5+ — sources musicales actives (multi-select). Premier élément
  /// = provider par défaut pour les recherches sans param explicite.
  active_providers String[] @default(["demo"])
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @updatedAt @db.Timestamptz(6)

  workspace     Workspace     @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  playlists     Playlist[]
  question_sets QuestionSet[]
  sessions      Session[]

  @@index([workspace_id])
  @@map("establishments")
}

// ─────────────────────────────────────────────────────────────────────────────
//  MUSIC_PROVIDER_CREDENTIALS (tokens OAuth, stockés chiffrés)
// ─────────────────────────────────────────────────────────────────────────────

model MusicProviderCredential {
  id            String    @id @default(uuid()) @db.Uuid
  workspace_id  String    @db.Uuid
  provider      String    @db.VarChar(32) // "spotify", "deezer", "apple_music"
  access_token  String // chiffré (pgcrypto, voir migration RLS/encryption)
  refresh_token String?
  expires_at    DateTime? @db.Timestamptz(6)
  account_email String?
  created_at    DateTime  @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, provider])
  @@map("music_provider_credentials")
}

// ─────────────────────────────────────────────────────────────────────────────
//  PLAYLISTS (Tutti Tracks)
// ─────────────────────────────────────────────────────────────────────────────

model Playlist {
  id                   String    @id @default(uuid()) @db.Uuid
  establishment_id     String    @db.Uuid
  name                 String
  description          String? // V1.1 : utile pour les playlists Tutti curées
  cover_url            String?
  level                Level     @default(MEDIUM)
  language             String    @default("fr") @db.VarChar(8)
  is_published         Boolean   @default(false)
  is_express           Boolean   @default(false) // V1 : créée à la volée pendant une session
  is_official_tutti    Boolean   @default(false) // V1.1 : playlist curée par Tutti (catalogue partagé)
  external_links       Json? // V1.1 : { spotify: url, deezer: url, apple_music: url }
  /// feat/playlist-cache-and-availability-check — dernière vérification de
  /// disponibilité (POST /check-availability) + nombre de tracks non
  /// jouables détectées. Affiché côté UI (badge / bouton coloré).
  last_checked_at      DateTime? @db.Timestamptz(6)
  unplayable_count     Int       @default(0)
  /// feat/playlist-pool-random-selection — nombre de tracks pickés
  /// aléatoirement dans le pool à chaque lancement d'une manche. Une
  /// playlist devient un POOL de N tracks (~60-80) dans lequel on tire
  /// `default_session_size` morceaux (anti-doublons via PR C).
  /// Default 15. Editable depuis /admin/library/playlists/:id.
  default_session_size Int       @default(15)
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime  @updatedAt @db.Timestamptz(6)

  establishment   Establishment   @relation(fields: [establishment_id], references: [id], onDelete: Cascade)
  playlist_tracks PlaylistTrack[]
  session_rounds  SessionRound[]

  @@index([establishment_id])
  @@map("playlists")
}

enum Level {
  EASY
  MEDIUM
  EXPERT

  @@map("level")
}

// ─────────────────────────────────────────────────────────────────────────────
//  SONGS (catalogue canonique de chansons — feat/canonical-song-catalog)
//
//  Principe : les aliases appartiennent à la CHANSON (titre+artiste), pas au
//  videoId. La même chanson existe sous plusieurs liens YouTube (clip, audio,
//  lyric video). official_playlist_tracks et tracks pointent vers la Song
//  canonique via song_id. Les aliases TITRE vivent ici ; les aliases ARTISTE
//  sur Artist (déjà dédupliqué par canonical_name).
// ─────────────────────────────────────────────────────────────────────────────

model Song {
  id              String   @id @default(uuid()) @db.Uuid
  artist_id       String   @db.Uuid
  canonical_title String
  /// Clé de matching : norm(artiste)|norm(titre) — lowercase, accents +
  /// ponctuation strip, suffixes parasites retirés ("(Official Video)",
  /// "Remastered 2009"…), feat./ft. exclu de la clé. Calculée par
  /// lib/songCatalog.songKey(). UNIQUE = dédup garantie à l'ingest.
  normalized_key  String   @unique @db.VarChar(300)
  /// Aliases de prononciation du TITRE (aliases artiste → Artist.aliases).
  title_aliases   String[] @default([])
  aliases_source  String?  @db.VarChar(16)

  // ─── feat/song-tags-classification (ÉTAPE 1) ──────────────────────────────
  // Tags de classification portés par la CHANSON canonique. Une playlist
  // devient une requête (theme, langue, niveau_max) sur ces tags ; le pick
  // reste capé à 15 (règle absolue). Tout additif/nullable → zéro casse.
  /// Slugs de thèmes (multi). Vocabulaire canonique : lib/songThemes.ts.
  themes          String[] @default([])
  /// Langue : 2 booléens INDÉPENDANTS (un titre peut être les deux = mixte).
  /// francophone = titre FR OU artiste francophone ; international = titre
  /// anglais connu hors zone franco OU artiste non-francophone.
  is_francophone  Boolean  @default(false)
  is_international Boolean  @default(false)
  /// Niveau 1 | 2 | 3. Sélection cumulative : niveau N pioche dans 1..N.
  /// null = pas encore tagué.
  level           Int?
  /// ÉTAPE 2 — pour les thèmes "œuvre" (film/série/dessin animé/jeu/comédie
  /// musicale) : la RÉPONSE et l'affichage = le nom de l'œuvre, pas l'artiste.
  work_title      String?
  /// Type d'œuvre : film|serie|dessin_anime|jeu_video|comedie_musicale.
  work_kind       String?  @db.VarChar(24)
  /// false = tags posés par la passe auto (ÉTAPE 3), à vérifier à la main
  /// dans l'UI biblio (ÉTAPE 4). true = relu/validé par un humain.
  tags_reviewed   Boolean  @default(false)
  // ──────────────────────────────────────────────────────────────────────────

  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @updatedAt @db.Timestamptz(6)

  artist           Artist                  @relation(fields: [artist_id], references: [id], onDelete: Restrict)
  catalog_tracks   OfficialPlaylistTrack[]
  workspace_tracks Track[]

  @@index([artist_id])
  @@index([level])
  @@index([themes], type: Gin)
  @@map("songs")
}

// ─────────────────────────────────────────────────────────────────────────────
//  ARTISTS (catalogue partagé global, aliases globaux pour matching vocal)
// ─────────────────────────────────────────────────────────────────────────────

model Artist {
  id             String   @id @default(uuid()) @db.Uuid
  canonical_name String   @unique
  aliases        String[] @default([]) // ex: ["stromaé", "stomei", "stromaye"]
  /// feat/ai-aliases-voice-matching — timestamp de la dernière génération
  /// d'aliases (via IA, script, ou édition manuelle). null = pas encore généré.
  aliases_generated_at DateTime? @db.Timestamptz(6)
  /// feat/ai-aliases-voice-matching — origine des aliases courants.
  /// Valeurs : 'manual' (édité par admin), 'ai' (Claude Haiku),
  /// 'learned' (auto-apprentissage VoiceTranscript V1.1), 'phonetic' (heuristique).
  aliases_source String? @db.VarChar(16)
  language       String?  @db.VarChar(8)
  origin_country String?  @db.VarChar(8)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @updatedAt @db.Timestamptz(6)

  tracks Track[]
  songs  Song[]

  @@map("artists")
}

// ─────────────────────────────────────────────────────────────────────────────
//  TRACKS (catalogue partagé global, lié à un Artist, indépendant des playlists)
// ─────────────────────────────────────────────────────────────────────────────

model Track {
  id                     String    @id @default(uuid()) @db.Uuid
  artist_id              String    @db.Uuid
  canonical_title        String
  aliases                String[]  @default([]) // alias du titre (ex: "alors on dance", "danse alors")
  /// feat/ai-aliases-voice-matching — métadonnées de génération d'aliases.
  aliases_generated_at   DateTime? @db.Timestamptz(6)
  aliases_source         String?   @db.VarChar(16)
  album                  String?
  year                   Int?
  genre                  String?
  popularity             Int? // 0-100, score Spotify
  duration_ms            Int?
  cover_url              String?
  provider               String    @db.VarChar(32) // "spotify", "demo"
  provider_track_id      String    @db.VarChar(128)
  /// feat/playlist-cache-and-availability-check — flag de jouabilité
  /// alimenté par POST /api/playlists/:id/check-availability. Pour YouTube :
  /// vérifie embeddable + privacy + region restriction. is_playable=false
  /// → track skip lors du clone-on-launch côté host (cohérent avec
  /// OfficialPlaylistTrack.is_playable).
  is_playable            Boolean   @default(true)
  playability_reason     String?
  playability_checked_at DateTime? @db.Timestamptz(6)
  /// feat/youtube-compliance — timestamp du dernier rafraîchissement automatique
  /// (cron 30 jours) ou manuel (POST /api/admin/refresh-youtube-data).
  /// YouTube API Services Developer Policies III.E.4 : les données API doivent
  /// être rafraîchies/supprimées au moins tous les 30 jours.
  last_refreshed_at      DateTime? @db.Timestamptz(6)
  /// feat/canonical-song-catalog — pointeur vers la chanson canonique.
  /// Nullable : backfillé par scripts/migrateCanonicalSongs.ts, rempli à
  /// l'ingest pour les nouvelles tracks.
  song_id                String?   @db.Uuid
  created_at             DateTime  @default(now()) @db.Timestamptz(6)

  artist          Artist               @relation(fields: [artist_id], references: [id], onDelete: Restrict)
  song            Song?                @relation(fields: [song_id], references: [id], onDelete: SetNull)
  playlist_tracks PlaylistTrack[]
  voice_logs      VoiceTranscript[]
  session_played  SessionPlayedTrack[]

  @@index([artist_id])
  @@index([provider, provider_track_id])
  @@index([is_playable])
  @@index([last_refreshed_at])
  @@index([song_id])
  @@map("tracks")
}

// ─────────────────────────────────────────────────────────────────────────────
//  PLAYLIST_TRACKS (table de jointure playlist ↔ track avec ordre)
// ─────────────────────────────────────────────────────────────────────────────

model PlaylistTrack {
  id          String   @id @default(uuid()) @db.Uuid
  playlist_id String   @db.Uuid
  track_id    String   @db.Uuid
  position    Int
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  playlist Playlist @relation(fields: [playlist_id], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [track_id], references: [id], onDelete: Cascade)

  @@unique([playlist_id, position])
  @@unique([playlist_id, track_id])
  @@index([track_id])
  @@map("playlist_tracks")
}

// ─────────────────────────────────────────────────────────────────────────────
//  QUESTION_SETS (Tutti Quizz — packs de questions)
// ─────────────────────────────────────────────────────────────────────────────

model QuestionSet {
  id               String   @id @default(uuid()) @db.Uuid
  establishment_id String?  @db.Uuid // null = pack générique partagé
  name             String
  description      String?
  cover_url        String?
  is_bilingual     Boolean  @default(false)
  language_1       String   @default("fr") @db.VarChar(8)
  language_2       String?  @db.VarChar(8)
  is_generic       Boolean  @default(false)
  is_published     Boolean  @default(false)
  created_at       DateTime @default(now()) @db.Timestamptz(6)

  establishment Establishment? @relation(fields: [establishment_id], references: [id], onDelete: Cascade)
  questions     Question[]

  @@index([establishment_id])
  @@map("question_sets")
}

// ─────────────────────────────────────────────────────────────────────────────
//  QUESTIONS
// ─────────────────────────────────────────────────────────────────────────────

model Question {
  id                   String       @id @default(uuid()) @db.Uuid
  set_id               String       @db.Uuid
  position             Int
  type                 QuestionType
  category             String?
  text_lang1           String
  text_lang2           String?
  // MCQ : choix proposés (4 typiquement). TRUE_FALSE/FREE_TEXT/ESTIMATION : []
  choices_lang1        String[]     @default([])
  choices_lang2        String[]     @default([])
  // MCQ/TRUE_FALSE : la réponse exacte ("Beatles", "true").
  // FREE_TEXT       : la réponse canonique (matchée + aliases ci-dessous).
  // ESTIMATION      : JSON encodé { "target": 1953, "min": 1900, "max": 2000, "unit": "année" }.
  answer_lang1         String
  answer_lang2         String?
  // FREE_TEXT uniquement : alternatives orthographiques acceptées en plus
  // de answer_lang1. Match fuzzy après normalize (lowercase, accents, etc).
  // Pas utilisés pour MCQ / TRUE_FALSE / ESTIMATION.
  answer_aliases_lang1 String[]     @default([])
  answer_aliases_lang2 String[]     @default([])
  time_limit_sec       Int          @default(30)
  points               Int          @default(100)
  media_type           MediaType    @default(NONE)
  media_url            String?
  /// feat/quiz-question-media — embed YouTube structuré (AUDIO/VIDEO).
  /// Propagé depuis OfficialQuizQuestion lors du clone-on-launch quiz pack.
  media_youtube_id     String?
  media_start_sec      Int?
  media_duration_sec   Int?
  created_at           DateTime     @default(now()) @db.Timestamptz(6)

  set QuestionSet @relation(fields: [set_id], references: [id], onDelete: Cascade)

  @@index([set_id, position])
  @@map("questions")
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  FREE_TEXT
  ESTIMATION

  @@map("question_type")
}

enum MediaType {
  NONE
  VIDEO
  AUDIO
  IMAGE

  @@map("media_type")
}

// ─────────────────────────────────────────────────────────────────────────────
//  SESSIONS (instance de jeu)
// ─────────────────────────────────────────────────────────────────────────────

model Session {
  id                  String        @id @default(uuid()) @db.Uuid
  establishment_id    String        @db.Uuid
  name                String? // étiquette éditable optionnelle ("Anniv Marc 29/04")
  game_type           GameType
  status              SessionStatus @default(WAITING)
  short_code          String        @unique @db.VarChar(16) // "KOMP-7K2X"
  /// feat/tv-join-code-multidevice — code court (5 chars, alphabet non
  /// ambigu) pour qu'un 2e device rejoigne en mode "Écran TV" via /tv/{CODE}
  /// ou saisie manuelle sur /tv. Lié à la session, mort quand elle se termine.
  /// Distinct de short_code (8 chars, code joueur).
  tv_code             String?       @unique @db.VarChar(8)
  mode                GameMode      @default(SOLO)
  teams_config        Json? // [{id, name, color, ...}]
  language            String        @default("fr") @db.VarChar(8)
  question_set_id     String?       @db.Uuid // pour Tutti Quizz (étape 15+)
  // Mode A = avec animateur (host pilote depuis l'iPad/Mac).
  // Mode B = sans animateur, défaut B2C : un joueur master pilote depuis son tel.
  has_animator        Boolean       @default(false)
  // Pause master en mode B. Pas d'auto-resume — c'est le master qui
  // déclenche la reprise. Le timer continue de courir (V1 simple).
  is_paused           Boolean       @default(false)
  // Durée de la fenêtre micro joueur (10s défaut, 15s en mode "détendu").
  buzz_window_seconds Int           @default(10)
  // Cap technique de participants par session (15 V1 pour B2C).
  max_participants    Int           @default(15)
  created_at          DateTime      @default(now()) @db.Timestamptz(6)
  /// Bumpé à chaque update Prisma. Utilisé par findRepresentativeSession
  /// pour ordonner les candidats (orderBy updated_at desc) — un session
  /// ENDED via POST /:id/end aura un updated_at plus récent qu'une zombie
  /// PLAYING jamais touchée. Anti-bug "TV bloquée sur ancienne session".
  updated_at          DateTime      @updatedAt @db.Timestamptz(6)
  started_at          DateTime?     @db.Timestamptz(6)
  ended_at            DateTime?     @db.Timestamptz(6)

  establishment      Establishment        @relation(fields: [establishment_id], references: [id], onDelete: Cascade)
  participants       Participant[]
  rounds             SessionRound[] // succession de manches
  score_events       ScoreEvent[]
  voice_transcripts  VoiceTranscript[]
  played_tracks      SessionPlayedTrack[]
  playlist_proposals PlaylistProposal[]

  @@index([short_code])
  @@index([establishment_id])
  @@map("sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
//  PLAYLIST_PROPOSALS — feat/tv-playlist-carousel
//
//  Pendant la phase lobby (Session.status = WAITING), un joueur peut proposer
//  une playlist officielle à l'animateur depuis son smartphone. L'host voit
//  les propositions et peut décider de lancer celle qui a le plus de votes.
//
//  Unique (session, participant, playlist) → un même joueur ne peut proposer
//  qu'une fois la même playlist (anti-spam). Peut en proposer plusieurs.
// ─────────────────────────────────────────────────────────────────────────────

model PlaylistProposal {
  id                   String   @id @default(uuid()) @db.Uuid
  session_id           String   @db.Uuid
  participant_id       String   @db.Uuid
  /// Référence à la playlist OFFICIELLE Tutti (catalogue partagé). Le host
  /// peut ensuite lancer la playlist via le flow POST /api/library/playlists/
  /// :id/launch existant. On stocke aussi le name snapshot pour fallback UI.
  official_playlist_id String   @db.Uuid
  playlist_name        String   @db.VarChar(200)
  created_at           DateTime @default(now()) @db.Timestamptz(6)

  session     Session     @relation(fields: [session_id], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participant_id], references: [id], onDelete: Cascade)

  @@unique([session_id, participant_id, official_playlist_id])
  @@index([session_id])
  @@index([official_playlist_id])
  @@map("playlist_proposals")
}

// ─────────────────────────────────────────────────────────────────────────────
//  SESSION_PLAYED_TRACKS — anti-doublon cross-playlist (PR C #53, restauré
//  après conflit rebase PR A sur main qui contenait déjà PR B + PR C).
// ─────────────────────────────────────────────────────────────────────────────

model SessionPlayedTrack {
  id         String   @id @default(uuid()) @db.Uuid
  session_id String   @db.Uuid
  track_id   String   @db.Uuid
  played_at  DateTime @default(now()) @db.Timestamptz(6)

  session Session @relation(fields: [session_id], references: [id], onDelete: Cascade)
  track   Track   @relation(fields: [track_id], references: [id], onDelete: Cascade)

  @@unique([session_id, track_id])
  @@index([session_id])
  @@map("session_played_tracks")
}

// ─────────────────────────────────────────────────────────────────────────────
//  SESSION_ROUNDS (manches d'une session — chaque manche = 1 playlist)
// ─────────────────────────────────────────────────────────────────────────────

model SessionRound {
  id                  String      @id @default(uuid()) @db.Uuid
  session_id          String      @db.Uuid
  playlist_id         String      @db.Uuid
  position            Int // 1, 2, 3...
  status              RoundStatus @default(PENDING)
  current_track_index Int         @default(0) // pour reprendre la manche après pause
  /// feat/playlist-pool-random-selection — sous-ensemble ordonné de tracks
  /// pickés au lancement de la manche depuis le pool de la playlist (default
  /// 15 / Playlist.default_session_size). Tracks anti-doublonnés via
  /// SessionPlayedTrack (PR C). Array vide → fallback rétro-compat sur la
  /// totalité de playlist.playlist_tracks.
  selected_track_ids  String[]    @default([]) @db.Uuid
  started_at          DateTime?   @db.Timestamptz(6)
  ended_at            DateTime?   @db.Timestamptz(6)
  created_at          DateTime    @default(now()) @db.Timestamptz(6)

  session  Session      @relation(fields: [session_id], references: [id], onDelete: Cascade)
  playlist Playlist     @relation(fields: [playlist_id], references: [id])
  events   ScoreEvent[]

  @@unique([session_id, position])
  @@index([session_id, position])
  @@map("session_rounds")
}

enum RoundStatus {
  PENDING
  PLAYING
  ENDED

  @@map("round_status")
}

enum GameType {
  TRACKS
  QUIZZ

  @@map("game_type")
}

enum GameMode {
  SOLO
  TEAMS

  @@map("game_mode")
}

enum SessionStatus {
  WAITING
  PLAYING
  ENDED

  @@map("session_status")
}

// ─────────────────────────────────────────────────────────────────────────────
//  PARTICIPANTS (joueurs anonymes connectés à une session)
// ─────────────────────────────────────────────────────────────────────────────

/// feat/multi-animator-roles — rôle d'un participant. PLAYER = joueur.
/// ANIMATOR_FULL = pilote la partie ET voit les réponses en avance.
/// ANIMATOR_PLAYING = pilote MAIS ne voit pas les réponses avant le reveal
/// (peut jouer). Plusieurs animateurs simultanés. is_master reste synchronisé
/// (rétro-compat : is_master = role != PLAYER).
enum ParticipantRole {
  PLAYER
  ANIMATOR_FULL
  ANIMATOR_PLAYING

  @@map("participant_role")
}

model Participant {
  id          String          @id @default(uuid()) @db.Uuid
  session_id  String          @db.Uuid
  pseudo      String          @db.VarChar(64)
  team_id     String?         @db.Uuid // référence à teams_config[].id (côté Json)
  is_master   Boolean         @default(false)
  /// feat/multi-animator-roles — source de vérité du rôle ; is_master reste
  /// synchronisé (true dès qu'un rôle animateur) pour l'ancien code.
  role        ParticipantRole @default(PLAYER)
  is_kicked   Boolean         @default(false)
  fingerprint String? // empreinte navigateur pour anti-spam
  joined_at   DateTime        @default(now()) @db.Timestamptz(6)

  session            Session            @relation(fields: [session_id], references: [id], onDelete: Cascade)
  score_events       ScoreEvent[]
  voice_transcripts  VoiceTranscript[]
  playlist_proposals PlaylistProposal[]

  @@index([session_id])
  @@map("participants")
}

// ─────────────────────────────────────────────────────────────────────────────
//  SCORE_EVENTS (journal d'audit complet de la partie)
// ─────────────────────────────────────────────────────────────────────────────

model ScoreEvent {
  id               String         @id @default(uuid()) @db.Uuid
  session_id       String         @db.Uuid
  session_round_id String?        @db.Uuid // null pour les events hors-manche (ajustements globaux)
  participant_id   String         @db.Uuid
  team_id          String?        @db.Uuid
  round_index      Int // index du morceau dans la manche (0-based)
  type             ScoreEventType
  points           Int // peut être négatif
  buzz_time_ms     Int? // pour TRACKS
  match_artist     Boolean? // pour TRACKS
  match_title      Boolean? // pour TRACKS
  voice_transcript String? // ce que Whisper a entendu (TRACKS)
  answer           String? // pour QUIZZ
  reason           String? // "voice_validation", "tech_bug", "fair_play", "cheating"
  is_public        Boolean        @default(true)
  applied_by       String?        @db.Uuid // user_id de l'host qui a appliqué l'ajustement
  created_at       DateTime       @default(now()) @db.Timestamptz(6)

  session     Session       @relation(fields: [session_id], references: [id], onDelete: Cascade)
  round       SessionRound? @relation(fields: [session_round_id], references: [id], onDelete: Cascade)
  participant Participant   @relation(fields: [participant_id], references: [id], onDelete: Cascade)

  @@index([session_id, round_index])
  @@index([session_round_id])
  @@index([participant_id])
  @@map("score_events")
}

enum ScoreEventType {
  ARTIST_FOUND
  TITLE_BONUS
  MVP_BONUS
  CORRECT_ANSWER
  SPEED_BONUS
  MANUAL_ADJUSTMENT

  @@map("score_event_type")
}

// ─────────────────────────────────────────────────────────────────────────────
//  VOICE_TRANSCRIPTS (logging Whisper pour auto-apprentissage des aliases V1.1)
// ─────────────────────────────────────────────────────────────────────────────

model VoiceTranscript {
  id             String   @id @default(uuid()) @db.Uuid
  session_id     String   @db.Uuid
  participant_id String   @db.Uuid
  track_id       String   @db.Uuid
  transcript     String
  matched_artist Boolean  @default(false)
  matched_title  Boolean  @default(false)
  confidence     Float?
  /// feat/voice-cascade-l3-assemblyai — niveau cascade qui a produit ce
  /// transcript. Valeurs : 'web-speech', 'deepgram', 'whisper-fallback',
  /// 'assemblyai', 'manual-text'. Nullable pour rétro-compat (anciennes lignes
  /// pré-cascade restent NULL).
  level          String?  @db.VarChar(32)
  /// Latence totale côté backend pour produire le transcript (ms). Nullable
  /// car non disponible pour les anciennes lignes.
  latency_ms     Int?
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  session     Session     @relation(fields: [session_id], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participant_id], references: [id], onDelete: Cascade)
  track       Track       @relation(fields: [track_id], references: [id], onDelete: Cascade)

  @@index([session_id])
  @@index([track_id])
  @@index([level])
  @@map("voice_transcripts")
}

// ─────────────────────────────────────────────────────────────────────────────
//  BIBLIOTHÈQUE OFFICIELLE TUTTI (catalogue propriétaire)
//
//  Stockage en DB Supabase. Les tracks sont matchés via Spotify Search +
//  YouTube Data v3 au moment de l'import (script scripts/import-official-
//  library.ts). Au runtime, le joueur lit ces morceaux via Web Playback SDK
//  avec son propre compte Spotify Premium (ou via YouTube IFrame Player s'il
//  préfère). Tutti ne stocke ni ne redistribue aucun fichier audio.
//
//  Visibility :
//    - public      : disponible à tous les workspaces (free + premium)
//    - premium_only: réservé aux plans payants (plus tard, V1.1)
//    - private     : caché — usage interne / brouillon admin
// ─────────────────────────────────────────────────────────────────────────────

model OfficialPlaylist {
  id                   String             @id @default(uuid()) @db.Uuid
  /// Slug stable utilisé dans le JSON source pour upsert idempotent
  /// (ex: "official-pl-italo-disco-classics"). Sert de clé naturelle.
  slug                 String             @unique @db.VarChar(120)
  name_fr              String
  name_en              String
  description_fr       String?
  description_en       String?
  /// Locale principale du contenu (utile pour la reconnaissance vocale et
  /// pour filtrer par langue côté UI). Ex: "fr-FR", "en-US", "it-IT", "es-ES".
  locale_primary       String             @db.VarChar(32)
  /// Thème éditorial (libre, ex: "italo-disco-classics", "french-pop-2010s").
  theme                String?            @db.VarChar(80)
  /// Niveau de difficulté global (EASY/MEDIUM/EXPERT — réutilise enum Level).
  difficulty           Level              @default(MEDIUM)
  visibility           OfficialVisibility @default(public)
  track_count          Int                @default(0)
  /// feat/tv-carousel-polish — URL d'une cover mosaïque 2×2 générée à partir
  /// des 4 premières cover_url des tracks du pool. Servie par
  /// GET /api/library-cover/:slug.jpg (génération dynamique on-demand, cache
  /// in-memory). Nullable — fallback texte côté UI si non-set.
  cover_url            String?
  /// feat/playlist-categories-schema — slug de catégorie pour le grouping
  /// dans l'UI sélection host + carrousel TV. Valeurs canoniques définies
  /// dans backend/src/lib/playlistCategories.ts (classics, originals,
  /// forbidden_30, wedding, decades, genres, special). Nullable pour les
  /// playlists pas encore catégorisées (legacy ou futures).
  category             String?            @db.VarChar(40)
  /// Ordre d'affichage dans la catégorie. Plus petit = affiché en premier.
  /// Tri stable : SI null → triée à la fin (par updated_at desc).
  position_in_category Int?
  /// Sous-titre court affiché sous le nom dans les cards (ex: "Pour les
  /// nostalgiques du Walkman"). Bilingue FR/EN. Backfill auto depuis le
  /// nom au seed initial, éditable par admin ensuite.
  subtitle_fr          String?            @db.VarChar(200)
  subtitle_en          String?            @db.VarChar(200)
  /// User_id Supabase de l'admin qui a créé/maintient la playlist (audit).
  /// Optionnel — un script qui tourne en CI peut être null.
  created_by_admin     String?            @db.Uuid
  /// feat/guess-work-mode — mode de "devine" :
  ///   - null (défaut) : matching contre artist+title (mode standard).
  ///   - 'work'        : matching contre work_title + work_aliases de la
  ///     track (= devine l'ŒUVRE, ex: "Le Roi Lion" pour la chanson
  ///     "Circle of Life"). Câblé au clone-on-launch (cf. library.ts).
  guess_mode           String?            @db.VarChar(16)
  created_at           DateTime           @default(now()) @db.Timestamptz(6)
  updated_at           DateTime           @updatedAt @db.Timestamptz(6)

  tracks OfficialPlaylistTrack[]

  @@index([visibility])
  @@index([locale_primary])
  @@index([category, position_in_category])
  @@map("official_playlists")
}

enum OfficialVisibility {
  public
  premium_only
  private

  @@map("official_visibility")
}

model OfficialPlaylistTrack {
  id                     String    @id @default(uuid()) @db.Uuid
  playlist_id            String    @db.Uuid
  /// Position dans la playlist (1-indexed, unique par playlist).
  position               Int
  title                  String
  artist                 String
  /// Année de sortie — utile pour le matching Spotify (year_range_strict).
  year                   Int?
  /// Niveau du morceau (peut différer du niveau global de la playlist).
  difficulty             Level     @default(MEDIUM)
  /// IDs canoniques résolus par le script d'import. null tant que pas matché.
  spotify_id             String?   @db.VarChar(40)
  youtube_id             String?   @db.VarChar(40)
  /// Réponses acceptées (artist + title aliases pour la reco vocale Whisper).
  /// Format JSON : { artist: string[], title: string[], full: string[] }
  answers_accepted       Json?
  /// URL cover album/track (récupérée via Spotify lors de l'import). Null si
  /// non résolue. Copiée dans Track.cover_url au moment du clone-on-launch.
  cover_url              String?
  /// Validé via YouTube Data API (status.embeddable + regionRestriction).
  /// false si vidéo non-embeddable, retirée, ou bloquée FR/LU. Le frontend
  /// host skip ces tracks au moment du clone-on-launch.
  is_playable            Boolean   @default(true)
  /// Raison de l'invalidation (null si is_playable=true). Ex: "not_embeddable",
  /// "blocked_FR", "blocked_LU", "video_not_found", "private_video".
  playability_reason     String?
  /// Timestamp de la dernière vérification YouTube API. Null si jamais validé.
  /// Re-run du script validate-youtube-ids met à jour cette colonne.
  playability_checked_at DateTime? @db.Timestamptz(6)
  /// feat/youtube-compliance — timestamp du dernier rafraîchissement automatique
  /// (cron 30 jours) ou manuel (POST /api/admin/refresh-youtube-data).
  /// YouTube API Services Developer Policies III.E.4 : les données API doivent
  /// être rafraîchies/supprimées au moins tous les 30 jours.
  last_refreshed_at      DateTime? @db.Timestamptz(6)
  /// Alias de prononciation curés par les super-admins pour le matching
  /// vocal Whisper. Mêmes sémantiques que Artist.aliases / Track.aliases côté
  /// playlists perso. Mergés au clone-on-launch dans Artist.aliases (artiste)
  /// et Track.aliases (titre) — propagation pour que voiceMatch les
  /// reconnaisse comme les playlists perso.
  artist_aliases         String[]  @default([])
  title_aliases          String[]  @default([])
  /// feat/canonical-song-catalog — pointeur vers la chanson canonique.
  /// Source de vérité des aliases : Song.title_aliases + Artist.aliases.
  /// Les colonnes artist_aliases/title_aliases ci-dessus restent en cache
  /// dénormalisé (lues par le clone-on-launch), resynchronisées depuis Song.
  song_id                String?   @db.Uuid
  /// feat/guess-work-mode — titre de l'ŒUVRE (film, série, dessin animé)
  /// dont la chanson est issue. La réponse à deviner si la playlist a
  /// `guess_mode = 'work'`. Ex: "The Lion King" pour la chanson "Circle of
  /// Life". Null pour les playlists standard (mode artist+title).
  work_title             String?
  /// feat/guess-work-mode — alias acceptés pour le work_title (traductions,
  /// raccourcis). Ex: ["Le Roi Lion"] pour "The Lion King". Mergés dans
  /// Track.aliases au clone-on-launch quand guess_mode='work'.
  work_aliases           String[]  @default([])
  created_at             DateTime  @default(now()) @db.Timestamptz(6)

  playlist OfficialPlaylist @relation(fields: [playlist_id], references: [id], onDelete: Cascade)
  song     Song?            @relation(fields: [song_id], references: [id], onDelete: SetNull)

  @@unique([playlist_id, position])
  @@index([playlist_id])
  @@index([spotify_id])
  @@index([youtube_id])
  @@index([is_playable])
  @@index([last_refreshed_at])
  @@index([song_id])
  @@map("official_playlist_tracks")
}

// ─────────────────────────────────────────────────────────────────────────────
//  OFFICIAL QUIZ LIBRARY (feat/official-quiz-library)
//  Bibliothèque officielle Tutti pour le mode Quizz. Parallèle à
//  OfficialPlaylist / OfficialPlaylistTrack mais pour questions/réponses.
// ─────────────────────────────────────────────────────────────────────────────

model OfficialQuizPack {
  id             String             @id @default(uuid()) @db.Uuid
  /// Slug stable utilisé dans le JSON source pour upsert idempotent
  /// (ex: "official-qz-animaux-nature"). Sert de clé naturelle.
  slug           String             @unique @db.VarChar(120)
  name_fr        String
  name_en        String
  description_fr String?
  description_en String?
  /// Locale principale (ex: "international", "fr", "en").
  locale_primary String             @db.VarChar(32)
  /// Catégorie éditoriale libre (ex: "animaux", "histoire", "cinema").
  category       String?            @db.VarChar(80)
  /// Niveau global (peut différer de la difficulté par question).
  difficulty     Level              @default(MEDIUM)
  visibility     OfficialVisibility @default(public)
  question_count Int                @default(0)
  created_at     DateTime           @default(now()) @db.Timestamptz(6)
  updated_at     DateTime           @updatedAt @db.Timestamptz(6)

  questions OfficialQuizQuestion[]

  @@index([visibility])
  @@index([locale_primary])
  @@index([category])
  @@map("official_quiz_packs")
}

model OfficialQuizQuestion {
  id                   String       @id @default(uuid()) @db.Uuid
  pack_id              String       @db.Uuid
  /// Position dans le pack (1-indexed, unique par pack).
  position             Int
  /// Type de question — mappé sur les 3 types présents dans les JSON
  /// sources (multiple_choice / true_false / fill_blank). MCQ / TRUE_FALSE
  /// / FREE_TEXT côté enum DB (réutilise QuestionType existant).
  type                 QuestionType
  /// Énoncé bilingue.
  question_fr          String
  question_en          String
  /// Choix MCQ (4 typiquement). Vide pour TRUE_FALSE / FREE_TEXT.
  choices_fr           String[]     @default([])
  choices_en           String[]     @default([])
  /// Index réponse correcte pour MCQ (0-based). Null sinon.
  correct_answer_index Int?
  /// Réponse correcte pour TRUE_FALSE. Null sinon.
  correct_answer_bool  Boolean?
  /// Réponse texte canonique pour FREE_TEXT (fill_blank). Null sinon.
  correct_answer_fr    String?
  correct_answer_en    String?
  /// Alternatives orthographiques pour FREE_TEXT (matching fuzzy).
  alternatives_fr      String[]     @default([])
  alternatives_en      String[]     @default([])
  /// Explication affichée après réponse (bilingue).
  explanation_fr       String?
  explanation_en       String?
  /// Difficulté par question (peut différer du pack).
  difficulty           Level        @default(MEDIUM)
  /// URL média optionnelle (image/audio illustrant la question, legacy).
  media_url            String?
  /// feat/quiz-question-media — type de média structuré (NONE/AUDIO/VIDEO/IMAGE).
  /// Si AUDIO|VIDEO + media_youtube_id renseigné, le gameplay embed un IFrame
  /// YouTube qui joue [media_start_sec, media_start_sec + media_duration_sec].
  /// AUDIO = IFrame caché (audio only). VIDEO = IFrame visible.
  media_type           MediaType    @default(NONE)
  /// ID YouTube (11 chars). Source du média si media_type=AUDIO|VIDEO.
  media_youtube_id     String?
  /// Offset de début de lecture en secondes (ex: 30 pour skip intro).
  media_start_sec      Int?
  /// Durée de lecture en secondes (max 30 côté UI). Coupé après ce délai.
  media_duration_sec   Int?
  created_at           DateTime     @default(now()) @db.Timestamptz(6)

  pack OfficialQuizPack @relation(fields: [pack_id], references: [id], onDelete: Cascade)

  @@unique([pack_id, position])
  @@index([pack_id])
  @@map("official_quiz_questions")
}
