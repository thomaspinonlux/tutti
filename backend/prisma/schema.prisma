// Tutti — Schéma Prisma (multi-tenant strict)
//
// Convention: les colonnes en base sont en snake_case (via @map).
// Les modèles côté Prisma utilisent les noms du Document 02-ARCHITECTURE.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
//  WORKSPACES (entité de facturation)
// ─────────────────────────────────────────────────────────────────────────────

model Workspace {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  plan       Plan      @default(FREE)
  expires_at DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)

  members           WorkspaceMember[]
  establishments    Establishment[]
  music_credentials MusicProviderCredential[]

  @@map("workspaces")
}

enum Plan {
  FREE
  PAY_PER_NIGHT
  MONTHLY

  @@map("plan")
}

// ─────────────────────────────────────────────────────────────────────────────
//  WORKSPACE_MEMBERS (lien auth.users ↔ workspace, avec rôle)
// ─────────────────────────────────────────────────────────────────────────────

model WorkspaceMember {
  id           String   @id @default(uuid()) @db.Uuid
  workspace_id String   @db.Uuid
  user_id      String   @db.Uuid // référence auth.users.id (Supabase Auth)
  role         Role     @default(HOST)
  /// Phase 4 — Mode C : statut d'approbation manuelle.
  /// PENDING par défaut sauf si l'email est en whitelist ou si un
  /// invitation_code valide est utilisé à la création (→ APPROVED auto).
  /// Un super admin peut basculer PENDING → APPROVED ou REJECTED.
  status       MemberStatus @default(PENDING)
  /// Email du compte au moment de la création (snapshot — auth.users
  /// peut changer l'email mais ce champ reste pour audit).
  email        String?  @db.VarChar(320)
  /// Si la création est passée par un code invitation, on garde la trace
  /// du code utilisé (debug / traçabilité parrainage).
  invitation_code_used String? @db.VarChar(16)
  /// Date d'approbation (manuelle ou auto via whitelist/code). null
  /// tant que PENDING.
  approved_at  DateTime?  @db.Timestamptz(6)
  /// User id du super admin qui a approuvé (null si auto via whitelist
  /// ou code).
  approved_by  String?   @db.Uuid
  // Système de parrainage (V1.1) — auto-généré à la création du membre,
  // 6 caractères alphanumériques majuscules (ex. "K7P2X9").
  referral_code String?  @unique @db.VarChar(8)
  // Code du parrain si l'utilisateur s'est inscrit via un lien filleul.
  referrer_code String?  @db.VarChar(8)
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, user_id])
  @@index([user_id])
  @@index([status])
  @@map("workspace_members")
}

enum Role {
  OWNER
  HOST
  ANIMATOR

  @@map("role")
}

enum MemberStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("member_status")
}

// ─────────────────────────────────────────────────────────────────────────────
//  WHITELIST_EMAILS (Phase 4 — Mode C : approbation manuelle + bypass auto)
// ─────────────────────────────────────────────────────────────────────────────

/// Liste d'emails autoapprouvés à la création de compte. Si un nouvel
/// utilisateur s'inscrit avec un email présent dans cette table, son
/// WorkspaceMember est créé directement en APPROVED (pas de file d'attente).
/// Géré uniquement par les super admins.
model WhitelistEmail {
  id         String   @id @default(uuid()) @db.Uuid
  email      String   @unique @db.VarChar(320)
  /// Notes libres pour le super admin (ex: "ami early adopter", "prospect bar X")
  note       String?  @db.VarChar(500)
  /// User id du super admin qui a ajouté l'entrée.
  added_by   String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("whitelist_emails")
}

// ─────────────────────────────────────────────────────────────────────────────
//  INVITATION_CODES (Phase 4 — codes one-shot pour inscription auto-approuvée)
// ─────────────────────────────────────────────────────────────────────────────

/// Codes invitation générés par les super admins. Un code valide utilisé
/// lors de l'inscription bascule le WorkspaceMember directement en APPROVED.
/// Single-use par défaut (consumed_at une fois utilisé), expiration
/// optionnelle (expires_at). max_uses permet les codes multi-usage
/// (ex: campagne marketing avec un seul code partagé).
model InvitationCode {
  id           String   @id @default(uuid()) @db.Uuid
  code         String   @unique @db.VarChar(16)
  /// Notes libres (à qui ? campagne ?)
  note         String?  @db.VarChar(500)
  /// User id du super admin qui a généré le code.
  created_by   String   @db.Uuid
  /// Nombre d'utilisations max (null = illimité). Décompté dans uses_count.
  max_uses     Int?
  uses_count   Int      @default(0)
  expires_at   DateTime? @db.Timestamptz(6)
  /// Date du 1er use (info, pour audit). Avec max_uses=1, marque code consommé.
  first_used_at DateTime? @db.Timestamptz(6)
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  @@index([code])
  @@map("invitation_codes")
}

// ─────────────────────────────────────────────────────────────────────────────
//  ESTABLISHMENTS (lieu physique ou thème)
// ─────────────────────────────────────────────────────────────────────────────

model Establishment {
  id               String   @id @default(uuid()) @db.Uuid
  workspace_id     String   @db.Uuid
  name             String
  branding_logo    String?
  branding_color   String?
  default_language String   @default("fr") @db.VarChar(8)
  active_provider  String   @default("demo") @db.VarChar(32)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @updatedAt @db.Timestamptz(6)

  workspace     Workspace     @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  playlists     Playlist[]
  question_sets QuestionSet[]
  sessions      Session[]

  @@index([workspace_id])
  @@map("establishments")
}

// ─────────────────────────────────────────────────────────────────────────────
//  MUSIC_PROVIDER_CREDENTIALS (tokens OAuth, stockés chiffrés)
// ─────────────────────────────────────────────────────────────────────────────

model MusicProviderCredential {
  id            String    @id @default(uuid()) @db.Uuid
  workspace_id  String    @db.Uuid
  provider      String    @db.VarChar(32) // "spotify", "deezer", "apple_music"
  access_token  String // chiffré (pgcrypto, voir migration RLS/encryption)
  refresh_token String?
  expires_at    DateTime? @db.Timestamptz(6)
  account_email String?
  created_at    DateTime  @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, provider])
  @@map("music_provider_credentials")
}

// ─────────────────────────────────────────────────────────────────────────────
//  PLAYLISTS (Tutti Tracks)
// ─────────────────────────────────────────────────────────────────────────────

model Playlist {
  id                String   @id @default(uuid()) @db.Uuid
  establishment_id  String   @db.Uuid
  name              String
  description       String? // V1.1 : utile pour les playlists Tutti curées
  cover_url         String?
  level             Level    @default(MEDIUM)
  language          String   @default("fr") @db.VarChar(8)
  is_published      Boolean  @default(false)
  is_express        Boolean  @default(false) // V1 : créée à la volée pendant une session
  is_official_tutti Boolean  @default(false) // V1.1 : playlist curée par Tutti (catalogue partagé)
  external_links    Json? // V1.1 : { spotify: url, deezer: url, apple_music: url }
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @updatedAt @db.Timestamptz(6)

  establishment   Establishment   @relation(fields: [establishment_id], references: [id], onDelete: Cascade)
  playlist_tracks PlaylistTrack[]
  session_rounds  SessionRound[]

  @@index([establishment_id])
  @@map("playlists")
}

enum Level {
  EASY
  MEDIUM
  EXPERT

  @@map("level")
}

// ─────────────────────────────────────────────────────────────────────────────
//  ARTISTS (catalogue partagé global, aliases globaux pour matching vocal)
// ─────────────────────────────────────────────────────────────────────────────

model Artist {
  id             String   @id @default(uuid()) @db.Uuid
  canonical_name String   @unique
  aliases        String[] @default([]) // ex: ["stromaé", "stomei", "stromaye"]
  language       String?  @db.VarChar(8)
  origin_country String?  @db.VarChar(8)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @updatedAt @db.Timestamptz(6)

  tracks Track[]

  @@map("artists")
}

// ─────────────────────────────────────────────────────────────────────────────
//  TRACKS (catalogue partagé global, lié à un Artist, indépendant des playlists)
// ─────────────────────────────────────────────────────────────────────────────

model Track {
  id                String   @id @default(uuid()) @db.Uuid
  artist_id         String   @db.Uuid
  canonical_title   String
  aliases           String[] @default([]) // alias du titre (ex: "alors on dance", "danse alors")
  album             String?
  year              Int?
  genre             String?
  popularity        Int? // 0-100, score Spotify
  duration_ms       Int?
  cover_url         String?
  provider          String   @db.VarChar(32) // "spotify", "demo"
  provider_track_id String   @db.VarChar(128)
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  artist          Artist          @relation(fields: [artist_id], references: [id], onDelete: Restrict)
  playlist_tracks PlaylistTrack[]
  voice_logs      VoiceTranscript[]

  @@index([artist_id])
  @@index([provider, provider_track_id])
  @@map("tracks")
}

// ─────────────────────────────────────────────────────────────────────────────
//  PLAYLIST_TRACKS (table de jointure playlist ↔ track avec ordre)
// ─────────────────────────────────────────────────────────────────────────────

model PlaylistTrack {
  id          String   @id @default(uuid()) @db.Uuid
  playlist_id String   @db.Uuid
  track_id    String   @db.Uuid
  position    Int
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  playlist Playlist @relation(fields: [playlist_id], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [track_id], references: [id], onDelete: Cascade)

  @@unique([playlist_id, position])
  @@unique([playlist_id, track_id])
  @@index([track_id])
  @@map("playlist_tracks")
}

// ─────────────────────────────────────────────────────────────────────────────
//  QUESTION_SETS (Tutti Quizz — packs de questions)
// ─────────────────────────────────────────────────────────────────────────────

model QuestionSet {
  id               String   @id @default(uuid()) @db.Uuid
  establishment_id String?  @db.Uuid // null = pack générique partagé
  name             String
  description      String?
  cover_url        String?
  is_bilingual     Boolean  @default(false)
  language_1       String   @default("fr") @db.VarChar(8)
  language_2       String?  @db.VarChar(8)
  is_generic       Boolean  @default(false)
  is_published     Boolean  @default(false)
  created_at       DateTime @default(now()) @db.Timestamptz(6)

  establishment Establishment? @relation(fields: [establishment_id], references: [id], onDelete: Cascade)
  questions     Question[]

  @@index([establishment_id])
  @@map("question_sets")
}

// ─────────────────────────────────────────────────────────────────────────────
//  QUESTIONS
// ─────────────────────────────────────────────────────────────────────────────

model Question {
  id                   String       @id @default(uuid()) @db.Uuid
  set_id               String       @db.Uuid
  position             Int
  type                 QuestionType
  category             String?
  text_lang1           String
  text_lang2           String?
  // MCQ : choix proposés (4 typiquement). TRUE_FALSE/FREE_TEXT/ESTIMATION : []
  choices_lang1        String[]     @default([])
  choices_lang2        String[]     @default([])
  // MCQ/TRUE_FALSE : la réponse exacte ("Beatles", "true").
  // FREE_TEXT       : la réponse canonique (matchée + aliases ci-dessous).
  // ESTIMATION      : JSON encodé { "target": 1953, "min": 1900, "max": 2000, "unit": "année" }.
  answer_lang1         String
  answer_lang2         String?
  // FREE_TEXT uniquement : alternatives orthographiques acceptées en plus
  // de answer_lang1. Match fuzzy après normalize (lowercase, accents, etc).
  // Pas utilisés pour MCQ / TRUE_FALSE / ESTIMATION.
  answer_aliases_lang1 String[]     @default([])
  answer_aliases_lang2 String[]     @default([])
  time_limit_sec       Int          @default(30)
  points               Int          @default(100)
  media_type           MediaType    @default(NONE)
  media_url            String?
  created_at           DateTime     @default(now()) @db.Timestamptz(6)

  set QuestionSet @relation(fields: [set_id], references: [id], onDelete: Cascade)

  @@index([set_id, position])
  @@map("questions")
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  FREE_TEXT
  ESTIMATION

  @@map("question_type")
}

enum MediaType {
  NONE
  VIDEO
  AUDIO
  IMAGE

  @@map("media_type")
}

// ─────────────────────────────────────────────────────────────────────────────
//  SESSIONS (instance de jeu)
// ─────────────────────────────────────────────────────────────────────────────

model Session {
  id               String        @id @default(uuid()) @db.Uuid
  establishment_id String        @db.Uuid
  name             String? // étiquette éditable optionnelle ("Anniv Marc 29/04")
  game_type        GameType
  status           SessionStatus @default(WAITING)
  short_code       String        @unique @db.VarChar(16) // "KOMP-7K2X"
  mode             GameMode      @default(SOLO)
  teams_config     Json? // [{id, name, color, ...}]
  language         String        @default("fr") @db.VarChar(8)
  question_set_id  String?       @db.Uuid // pour Tutti Quizz (étape 15+)
  // Mode A = avec animateur (host pilote depuis l'iPad/Mac).
  // Mode B = sans animateur, défaut B2C : un joueur master pilote depuis son tel.
  has_animator     Boolean       @default(false)
  // Pause master en mode B. Pas d'auto-resume — c'est le master qui
  // déclenche la reprise. Le timer continue de courir (V1 simple).
  is_paused        Boolean       @default(false)
  // Durée de la fenêtre micro joueur (10s défaut, 15s en mode "détendu").
  buzz_window_seconds Int        @default(10)
  // Cap technique de participants par session (15 V1 pour B2C).
  max_participants Int           @default(15)
  created_at       DateTime      @default(now()) @db.Timestamptz(6)
  started_at       DateTime?     @db.Timestamptz(6)
  ended_at         DateTime?     @db.Timestamptz(6)

  establishment     Establishment     @relation(fields: [establishment_id], references: [id], onDelete: Cascade)
  participants      Participant[]
  rounds            SessionRound[] // succession de manches
  score_events      ScoreEvent[]
  voice_transcripts VoiceTranscript[]

  @@index([short_code])
  @@index([establishment_id])
  @@map("sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
//  SESSION_ROUNDS (manches d'une session — chaque manche = 1 playlist)
// ─────────────────────────────────────────────────────────────────────────────

model SessionRound {
  id                  String      @id @default(uuid()) @db.Uuid
  session_id          String      @db.Uuid
  playlist_id         String      @db.Uuid
  position            Int // 1, 2, 3...
  status              RoundStatus @default(PENDING)
  current_track_index Int         @default(0) // pour reprendre la manche après pause
  started_at          DateTime?   @db.Timestamptz(6)
  ended_at            DateTime?   @db.Timestamptz(6)
  created_at          DateTime    @default(now()) @db.Timestamptz(6)

  session  Session      @relation(fields: [session_id], references: [id], onDelete: Cascade)
  playlist Playlist     @relation(fields: [playlist_id], references: [id])
  events   ScoreEvent[]

  @@unique([session_id, position])
  @@index([session_id, position])
  @@map("session_rounds")
}

enum RoundStatus {
  PENDING
  PLAYING
  ENDED

  @@map("round_status")
}

enum GameType {
  TRACKS
  QUIZZ

  @@map("game_type")
}

enum GameMode {
  SOLO
  TEAMS

  @@map("game_mode")
}

enum SessionStatus {
  WAITING
  PLAYING
  ENDED

  @@map("session_status")
}

// ─────────────────────────────────────────────────────────────────────────────
//  PARTICIPANTS (joueurs anonymes connectés à une session)
// ─────────────────────────────────────────────────────────────────────────────

model Participant {
  id          String   @id @default(uuid()) @db.Uuid
  session_id  String   @db.Uuid
  pseudo      String   @db.VarChar(64)
  team_id     String?  @db.Uuid // référence à teams_config[].id (côté Json)
  is_master   Boolean  @default(false)
  is_kicked   Boolean  @default(false)
  fingerprint String? // empreinte navigateur pour anti-spam
  joined_at   DateTime @default(now()) @db.Timestamptz(6)

  session           Session           @relation(fields: [session_id], references: [id], onDelete: Cascade)
  score_events      ScoreEvent[]
  voice_transcripts VoiceTranscript[]

  @@index([session_id])
  @@map("participants")
}

// ─────────────────────────────────────────────────────────────────────────────
//  SCORE_EVENTS (journal d'audit complet de la partie)
// ─────────────────────────────────────────────────────────────────────────────

model ScoreEvent {
  id               String         @id @default(uuid()) @db.Uuid
  session_id       String         @db.Uuid
  session_round_id String?        @db.Uuid // null pour les events hors-manche (ajustements globaux)
  participant_id   String         @db.Uuid
  team_id          String?        @db.Uuid
  round_index      Int // index du morceau dans la manche (0-based)
  type             ScoreEventType
  points           Int // peut être négatif
  buzz_time_ms     Int? // pour TRACKS
  match_artist     Boolean? // pour TRACKS
  match_title      Boolean? // pour TRACKS
  voice_transcript String? // ce que Whisper a entendu (TRACKS)
  answer           String? // pour QUIZZ
  reason           String? // "voice_validation", "tech_bug", "fair_play", "cheating"
  is_public        Boolean        @default(true)
  applied_by       String?        @db.Uuid // user_id de l'host qui a appliqué l'ajustement
  created_at       DateTime       @default(now()) @db.Timestamptz(6)

  session     Session       @relation(fields: [session_id], references: [id], onDelete: Cascade)
  round       SessionRound? @relation(fields: [session_round_id], references: [id], onDelete: Cascade)
  participant Participant   @relation(fields: [participant_id], references: [id], onDelete: Cascade)

  @@index([session_id, round_index])
  @@index([session_round_id])
  @@index([participant_id])
  @@map("score_events")
}

enum ScoreEventType {
  ARTIST_FOUND
  TITLE_BONUS
  MVP_BONUS
  CORRECT_ANSWER
  SPEED_BONUS
  MANUAL_ADJUSTMENT

  @@map("score_event_type")
}

// ─────────────────────────────────────────────────────────────────────────────
//  VOICE_TRANSCRIPTS (logging Whisper pour auto-apprentissage des aliases V1.1)
// ─────────────────────────────────────────────────────────────────────────────

model VoiceTranscript {
  id             String   @id @default(uuid()) @db.Uuid
  session_id     String   @db.Uuid
  participant_id String   @db.Uuid
  track_id       String   @db.Uuid
  transcript     String
  matched_artist Boolean  @default(false)
  matched_title  Boolean  @default(false)
  confidence     Float?
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  session     Session     @relation(fields: [session_id], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participant_id], references: [id], onDelete: Cascade)
  track       Track       @relation(fields: [track_id], references: [id], onDelete: Cascade)

  @@index([session_id])
  @@index([track_id])
  @@map("voice_transcripts")
}
