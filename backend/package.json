{
  "name": "@tutti/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test 'src/**/*.test.ts'",
    "lint": "eslint src --max-warnings 0",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "import:official-library": "tsx scripts/import-official-library.ts",
    "import:official-quiz": "tsx scripts/import-official-quiz.ts",
    "validate:youtube-ids": "tsx scripts/validate-youtube-ids.ts",
    "generate:aliases": "tsx scripts/generateAllAliases.ts",
    "generate:artist-aliases": "tsx scripts/generateAllArtistAliases.ts",
    "enrich:official-playlists": "tsx scripts/enrichOfficialPlaylists.ts",
    "enrich:spotify-ids": "tsx scripts/enrichSpotifyIds.ts",
    "enrich:apple-music-ids": "tsx scripts/enrichAppleMusicIds.ts",
    "sync:workspace-playlists": "tsx scripts/syncWorkspacePlaylists.ts",
    "backfill:catalog-aliases": "tsx scripts/backfillCatalogAliases.ts",
    "migrate:canonical-songs": "tsx scripts/migrateCanonicalSongs.ts",
    "import:canonical-songs": "tsx scripts/importCanonicalSongs.ts",
    "verify:canonical-ingest": "tsx scripts/verifyCanonicalIngest.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.101.0",
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "^2.105.1",
    "@tutti/shared": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "double-metaphone": "^2.0.1",
    "express": "^4.21.2",
    "multer": "^2.1.1",
    "p-limit": "^7.3.0",
    "resend": "^6.12.3",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "youtube-dl-exec": "^3.1.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
