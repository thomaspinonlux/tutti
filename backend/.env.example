# Tutti backend — variables d'environnement (exemple)
# Copier en .env et compléter. Ne JAMAIS committer le .env réel.

# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Supabase (étape 2+)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# JWT (étape 3+) — généré aléatoirement (`openssl rand -hex 32`)
JWT_SECRET=

# Spotify (étape 7+)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3001/auth/spotify/callback

# OpenAI / Whisper (étape 11+)
OPENAI_API_KEY=
